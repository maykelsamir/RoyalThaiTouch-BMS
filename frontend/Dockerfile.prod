FROM node:20-alpine AS build
WORKDIR /app
COPY package.json .
RUN npm install
COPY . .
# In production the browser must call the same public domain, not localhost on the employee computer.
RUN sed -i "s|const API='http://localhost:8000';|const API=window.location.origin + '/api';|" src/main.jsx
RUN npm run build

FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
